Script de pwnage:

# Matrix-style ASCII cascade: "PWNED BY KOLIRIO"

$Text = "PWNED BY KOLIRIO"
$Width = 80
$Height = 50
$Delay = 100    # milliseconds

$MatrixChars = @(
    "#", "@", "%", "&", "|", "-", "+", "*", "/", "\", ".", ":"
)

function Clear-Screen {
    Clear-Host
}

function Show-MatrixCascades {

    $lines = @()
    $chars = $Text.ToCharArray()
    $lineCount = 100

    for ($i = 0; $i -lt $lineCount; $i++) {

        $lines += [PSCustomObject]@{
            X    = Get-Random -Minimum 0 -Maximum $Width
            Y    = Get-Random -Minimum 0 -Maximum $Height
            Char = $chars[$(Get-Random -Minimum 0 -Maximum $chars.Length)]
        }
    }

    while ($true) {

        Clear-Screen

        foreach ($line in $lines) {

            if ($line.Y -lt $Height) {

                [Console]::SetCursorPosition($line.X,$line.Y)
                Write-Host $line.Char -ForegroundColor Green -NoNewline
            }
        }

        for ($i=0; $i -lt $lines.Count; $i++) {

            if ($lines[$i].Y -ge ($Height-1)) {

                $lines[$i] = [PSCustomObject]@{
                    X    = Get-Random -Minimum 0 -Maximum $Width
                    Y    = 0
                    Char = $chars[$(Get-Random -Minimum 0 -Maximum $chars.Length)]
                }

            } else {

                $lines[$i].Y++
            }
        }

        $blockChance = Get-Random -Minimum 0 -Maximum 100

        if ($blockChance -lt 5) {
            [Console]::SetCursorPosition(
                (Get-Random -Minimum 0 -Maximum $Width),
                (Get-Random -Minimum 0 -Maximum $Height)
            )
            Write-Host "█" -ForegroundColor Cyan -NoNewline
        }

        if ($blockChance -lt 10) {
            [Console]::SetCursorPosition(
                (Get-Random -Minimum 0 -Maximum $Width),
                (Get-Random -Minimum 0 -Maximum $Height)
            )
            Write-Host "▓" -ForegroundColor Blue -NoNewline
        }

        if ($blockChance -lt 15) {
            [Console]::SetCursorPosition(
                (Get-Random -Minimum 0 -Maximum $Width),
                (Get-Random -Minimum 0 -Maximum $Height)
            )
            Write-Host "░" -ForegroundColor DarkGray -NoNewline
        }

        Start-Sleep -Milliseconds $Delay
    }
}

